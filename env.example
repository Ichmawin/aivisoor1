# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AIVisoor
APP_ENV=production
APP_VERSION=1.0.0
APP_SECRET_KEY=change-me-minimum-32-chars-random-string
DEBUG=false
ALLOWED_ORIGINS=["https://app.aivisoor.com","http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aivisoor:password@localhost:5432/aivisoor
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-minimum-32-chars-random-jwt-key
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@aivisoor.com
EMAIL_FROM_NAME=AIVisoor

# ── Storage (S3-compatible — use Hetzner Object Storage or Cloudflare R2) ─────
S3_ENDPOINT=https://your-bucket.your-region.your-provider.com
S3_BUCKET=aivisoor
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_REGION=eu-central-1

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
